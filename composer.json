{
  "name": "dualmedia/symfony-request-dto-bundle",
  "type": "symfony-bundle",
  "description": "Symfony bundle which provides DTO object functionality and resolving",
  "keywords": [
    "dto",
    "symfony",
    "request"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "pkly",
      "homepage": "https://github.com/pkly",
      "role": "Author"
    }
  ],
  "require": {
    "php": ">=8.5",
    "dualmedia/doctrine-query-creator": "^1",
    "symfony/framework-bundle": "^7.4||^8.0",
    "symfony/event-dispatcher": "^7.4||^8.0",
    "symfony/validator": "^7.4||^8.0",
    "doctrine/collections": "^2.6",
    "symfony/type-info": "^7.4||^8.0"
  },
  "require-dev": {
    "ext-simplexml": "*",
    "phpunit/phpunit": "^13",
    "friendsofphp/php-cs-fixer": "^3",
    "pedrotroller/php-cs-custom-fixer": "^2",
    "phpstan/phpstan": "^2",
    "symfony/phpunit-bridge": "^7.4||^8.0",
    "matthiasnoback/symfony-dependency-injection-test": "^6",
    "nelmio/api-doc-bundle": "^5",
    "symfony/stopwatch": "^7.4||^8.0",
    "symfony/web-profiler-bundle": "^7.4||^8.0",
    "symfony/var-exporter": "^7.4||^8.0",
    "doctrine/doctrine-bundle": "^2",
    "doctrine/orm": "^3",
    "phpstan/phpstan-strict-rules": "^2.0",
    "jetbrains/phpstorm-attributes": "^1.2",
    "pkly/phpunit-service-create-trait": "^1.0",
    "phpstan/phpdoc-parser": "^2.3"
  },
  "conflict": {
    "nelmio/api-doc-bundle": "<5",
    "doctrine/doctrine-bundle": "<2.4"
  },
  "autoload": {
    "psr-4": {
      "DualMedia\\DtoRequestBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DualMedia\\DtoRequestBundle\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "php-cs-fixer fix",
    "test": "phpunit",
    "baseline": "vendor/bin/phpstan --generate-baseline"
  },
  "suggest": {
    "nelmio/api-doc-bundle": "Adds api docs for endpoints for your DTOs",
    "doctrine/doctrine-bundle": "Symfony's ORM of choice",
    "phpstan/phpdoc-parser": "Better type resolving related to PHPDoc objects"
  },
  "extra": {
    "symfony": {
      "require": "7.4.*",
      "allow-contrib": false
    }
  }
}
